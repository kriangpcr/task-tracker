{
  "name": "zappgo-backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start --watch",
    "start:dev": "cross-env NODE_ENV=development nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "prisma:push": "dotenv -e ./env/development.env -- npx prisma db push --schema ./prisma/schema.prisma",
    "prisma:pull": "dotenv -e ./env/development.env -- npx prisma db pull --schema ./prisma/schema.prisma",
    "prisma:migrate:dev": "dotenv -e ./env/development.env -- npx prisma migrate dev --name test --schema ./prisma/schema.prisma --create-only",
    "prisma:migrate:reset": "dotenv -e ./env/development.env -- npx prisma migrate reset",
    "prisma:migrate:deploy": "dotenv -e ./env/development.env -- npx prisma migrate deploy",
    "prisma:reset": "dotenv -e ./env/development.env npx prisma migrate reset",
    "prisma:studio": "dotenv -e ./env/development.env prisma studio --schema ./prisma/schema.prisma",
    "prisma:seed": "dotenv -e ./env/development.env npx prisma db seed",
    "prisma:generate": "prisma generate --schema ./prisma/schema.prisma",
    "prisma:migrate:uat:reset": "dotenv -e ./env/uat.env -- npx prisma migrate reset",
    "prisma:migrate:uat:deploy": "dotenv -e ./env/uat.env -- npx prisma migrate deploy",
    "prisma:studio:uat": "dotenv -e ./env/uat.env prisma studio --schema ./prisma/schema.prisma",
    "prisma:migrate:prod:deploy": "dotenv -e ./env/production.env -- npx prisma migrate deploy"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.2.6",
    "@prisma/client": "^6.9.0",
    "@supabase/supabase-js": "^2.110.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "cross-env": "^10.1.0",
    "fastify": "^5.10.0",
    "nestjs-form-data": "^11.0.1",
    "prisma": "^6.9.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/supertest": "^6.0.2",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
